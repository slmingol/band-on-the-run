      "strokeColor": "#1971c2",
      "backgroundColor": "#d0ebff",
      "roundness": {"type": 3}
    },
    {
      "type": "text",
      "id": "version-bump-text",
      "x": 120,
      "y": 345,
      "width": 380,
      "height": 190,
      "fontSize": 17,
      "fontFamily": 1,
      "text": "1️⃣ Version Bump Workflow\n\n• Trigger: Push to main\n• Skip if: [skip version] in commit\n• Parse semantic version: X.Y.Z\n• Bump: patch/minor/major\n• Update: VERSION, package.json\n• Commit: [skip version]\n• Create Git tag: vX.Y.Z\n• Push tag",
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "lineHeight": 1.25
    },
    {
      "type": "arrow",
      "id": "arrow-trigger-version",
      "x": 255,
      "y": 270,
      "width": 0,
      "height": 60,
      "strokeWidth": 3,
      "strokeColor": "#1971c2",
      "startArrowhead": null,
      "endArrowhead": "arrow",
      "points": [[0, 0], [0, 60]]
    },
    {
      "type": "rectangle",
      "id": "docker-build",
      "x": 580,
      "y": 330,
      "width": 420,
      "height": 280,
      "fillStyle": "solid",
      "strokeWidth": 3,
      "strokeColor": "#f76707",
      "backgroundColor": "#ffe8cc",
      "roundness": {"type": 3}
    },
    {
      "type": "text",
      "id": "docker-build-text",
      "x": 600,
      "y": 345,
      "width": 380,
      "height": 250,
      "fontSize": 17,
      "fontFamily": 1,
      "text": "2️⃣ Docker Build Workflow\n\n• Trigger: Push, PR, tag, manual\n• Read VERSION file\n• Build: Frontend (Nginx + React)\n  - Dockerfile: docker/Dockerfile\n  - Push to GHCR\n• Build: Backend (Express + Node)\n  - Dockerfile: docker/Dockerfile.backend\n  - Push to GHCR\n• Tags: latest, vX.Y.Z, branch\n• Cache: Registry + GitHub Actions",
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "lineHeight": 1.25
    },
